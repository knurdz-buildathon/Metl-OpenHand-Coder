# =============================================================================
# Metl Coding Agent - Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# --- Domain & SSL ------------------------------------------------------------
PREVIEW_BASE_DOMAIN=code.metl.run
LETSENCRYPT_EMAIL=admin@metl.run

# --- Database (SQLite - zero config) ----------------------------------------
# No external DB needed. SQLite file is stored in ./data/metl.db
DATABASE_URL=sqlite+aiosqlite:///app/data/metl.db

# --- Dashboard (Next.js - baked at build time) -------------------------------
NEXT_PUBLIC_API_URL=/api

# --- Azure AI Foundry (primary LLM - OpenAI-compatible endpoint) -------------
AZURE_AI_API_KEY=your-azure-foundry-api-key
AZURE_AI_BASE_URL=https://your-resource.cognitiveservices.azure.com/openai/deployments/your-deployment
AZURE_AI_MODEL=gpt-4o

# --- Other LLM Providers (optional fallbacks) --------------------------------
LLM_OPENAI_API_KEY=
LLM_ANTHROPIC_API_KEY=
LLM_GOOGLE_API_KEY=
LLM_MISTRAL_API_KEY=

# --- Preview Configuration ---------------------------------------------------
PREVIEW_PORT_RANGE_START=9000
PREVIEW_PORT_RANGE_END=9100

# --- Control Panel Webhook (where reports are sent) --------------------------
CONTROL_PANEL_WEBHOOK_URL=

# --- GitHub ------------------------------------------------------------------
GITHUB_TOKEN=ghp_your_github_personal_access_token

# --- OpenHands ---------------------------------------------------------------
OPENHANDS_IMAGE=ghcr.io/all-hands-ai/openhands:latest

# --- Job Execution -----------------------------------------------------------
JOB_EXECUTION_TIMEOUT=3600
MAX_ITERATIONS=10

# --- v0.dev (optional - leave empty to skip) ---------------------------------
V0_API_URL=
V0_API_KEY=

# --- Artifacts ---------------------------------------------------------------
ARTIFACTS_DIR=/tmp/metl-artifacts